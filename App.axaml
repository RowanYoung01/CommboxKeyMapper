<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ACU624KeyMapper.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#9090A0" />
        <FontFamily x:Key="MonoFont">Consolas,Menlo,DejaVu Sans Mono,monospace</FontFamily>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme DensityStyle="Compact" />

        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="TextBlock.subtle">
            <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="TextBlock.header">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#5294E2" />
        </Style>
        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Application.Styles>

</Application>
