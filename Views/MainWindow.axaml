<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ACU624KeyMapper.Views.MainWindow"
        Title="ACU-624D Key Mapper"
        Width="600" Height="750"
        MinWidth="520" MinHeight="600">

    <DockPanel>

        <!-- ── Top status bar ──────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid ColumnDefinitions="14,8,*,8,Auto">
                <Ellipse x:Name="_statusDot"
                         Width="10" Height="10"
                         Fill="Gray"
                         VerticalAlignment="Center" />
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="_statusLabel"
                               Text="Disconnected"
                               FontWeight="SemiBold" FontSize="13" />
                    <TextBlock x:Name="_deviceInfoLabel"
                               Text=""
                               Classes="subtle" />
                </StackPanel>
                <Button Grid.Column="4"
                        x:Name="_reconnectBtn"
                        Content="Reconnect"
                        Padding="12,5" />
            </Grid>
        </Border>

        <!-- ── Bottom status bar ───────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#3F3F46" BorderThickness="0,1,0,0"
                Padding="10,3">
            <TextBlock Text="ACU-624D Key Mapper  ·  VID:0000 PID:3200"
                       Classes="subtle" />
        </Border>

        <!-- ── Activity log ────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#3F3F46" BorderThickness="0,1,0,0"
                Height="130">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Padding="10,4"
                        BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                    <TextBlock Text="Activity Log"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#9090A0" />
                </Border>
                <ListBox x:Name="_logBox"
                         BorderThickness="0" Padding="4,2"
                         Background="#08090F"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="Consolas,Menlo,monospace"
                                       FontSize="11"
                                       Foreground="#72C882" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── Learn banner (hidden when idle) ─────────────────── -->
        <Border x:Name="_learnBanner"
                DockPanel.Dock="Top"
                IsVisible="False"
                Background="#3D2800"
                BorderBrush="#CC6600" BorderThickness="0,0,0,1"
                Padding="10,6">
            <TextBlock x:Name="_learnInfoLabel"
                       Text="Learning…"
                       Foreground="#FF9900" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
        </Border>

        <!-- ── Scrollable content ───────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Switch panels -->
                <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Grid ColumnDefinitions="*,8,1,8,*">
                        <!-- Left switch -->
                        <StackPanel Grid.Column="0" Spacing="5">
                            <TextBlock Text="&lt; Left Switch"
                                       Classes="header" />
                            <TextBlock x:Name="_leftStateLbl"
                                       Text="IDLE"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="#606070" />
                            <TextBlock Text="Action:"
                                       Classes="subtle" />
                            <ComboBox x:Name="_leftKeyCombo"
                                      HorizontalAlignment="Stretch" />
                            <CheckBox x:Name="_leftHoldChk"
                                      Content="Hold (release when switch released)"
                                      IsChecked="True" FontSize="11" />
                            <Button x:Name="_leftLearnBtn"
                                    Content="Learn Switch"
                                    HorizontalAlignment="Stretch"
                                    Padding="0,6" />
                            <TextBlock x:Name="_leftConfigLbl"
                                       Text="Not learned yet"
                                       FontSize="11"
                                       FontFamily="Consolas,monospace"
                                       Foreground="#606070" />
                        </StackPanel>
                        <!-- Divider -->
                        <Rectangle Grid.Column="2" Fill="#3F3F46" />
                        <!-- Right switch -->
                        <StackPanel Grid.Column="4" Spacing="5">
                            <TextBlock Text="Right Switch &gt;"
                                       Classes="header" />
                            <TextBlock x:Name="_rightStateLbl"
                                       Text="IDLE"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="#606070" />
                            <TextBlock Text="Action:"
                                       Classes="subtle" />
                            <ComboBox x:Name="_rightKeyCombo"
                                      HorizontalAlignment="Stretch" />
                            <CheckBox x:Name="_rightHoldChk"
                                      Content="Hold (release when switch released)"
                                      IsChecked="True" FontSize="11" />
                            <Button x:Name="_rightLearnBtn"
                                    Content="Learn Switch"
                                    HorizontalAlignment="Stretch"
                                    Padding="0,6" />
                            <TextBlock x:Name="_rightConfigLbl"
                                       Text="Not learned yet"
                                       FontSize="11"
                                       FontFamily="Consolas,monospace"
                                       Foreground="#606070" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Device display -->
                <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Grid ColumnDefinitions="Auto,12,Auto,8,*,8,Auto,8,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Display"
                                   Classes="header"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Background="#050F08"
                                BorderBrush="#1A3A1E" BorderThickness="1"
                                Padding="10,4" CornerRadius="3">
                            <TextBlock x:Name="_displayPreview"
                                       Text="                &#10;                "
                                       FontFamily="Consolas,Menlo,monospace"
                                       FontSize="11" FontWeight="Bold"
                                       LineHeight="16"
                                       Foreground="#44D282" />
                        </Border>
                        <TextBox x:Name="_displayTextBox"
                                 Grid.Column="4"
                                 MaxLength="16"
                                 FontFamily="Consolas,monospace"
                                 FontSize="11"
                                 VerticalAlignment="Center"
                                 Text="                " />
                        <CheckBox x:Name="_displayAutoChk"
                                  Grid.Column="6"
                                  Content="Auto"
                                  IsChecked="True"
                                  VerticalAlignment="Center" />
                        <Button x:Name="_sendDisplayBtn"
                                Grid.Column="8"
                                Content="Send"
                                VerticalAlignment="Center"
                                Padding="12,5" />
                    </Grid>
                </Border>

                <!-- Audio levels -->
                <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Grid ColumnDefinitions="Auto,12,Auto,*,Auto"
                          RowDefinitions="Auto,6,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Audio"
                                   Classes="header"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="Out:"
                                   Classes="subtle"
                                   VerticalAlignment="Center" />
                        <ProgressBar Grid.Row="0" Grid.Column="3"
                                     x:Name="_outVolBar"
                                     Minimum="0" Maximum="100" Value="0"
                                     Height="6" Margin="0,0,8,0"
                                     VerticalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="4"
                                   x:Name="_outVolLbl"
                                   Text="-- %"
                                   Classes="mono"
                                   VerticalAlignment="Center" MinWidth="44" />
                        <TextBlock Grid.Row="2" Grid.Column="2"
                                   Text="Mic:"
                                   Classes="subtle"
                                   VerticalAlignment="Center" />
                        <ProgressBar Grid.Row="2" Grid.Column="3"
                                     x:Name="_inVolBar"
                                     Minimum="0" Maximum="100" Value="0"
                                     Height="6" Margin="0,0,8,0"
                                     VerticalAlignment="Center" />
                        <TextBlock Grid.Row="2" Grid.Column="4"
                                   x:Name="_inVolLbl"
                                   Text="-- %"
                                   Classes="mono"
                                   VerticalAlignment="Center" MinWidth="44" />
                    </Grid>
                </Border>

                <!-- Sidetone -->
                <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <StackPanel Spacing="5">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="Sidetone"
                                       Classes="header"
                                       VerticalAlignment="Center" />
                            <CheckBox x:Name="_sidetoneChk"
                                      Content="Enable"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="Volume:"
                                       Classes="subtle"
                                       VerticalAlignment="Center" />
                            <Slider x:Name="_sidetoneSlider"
                                    Minimum="0" Maximum="100" Value="50"
                                    Width="180" VerticalAlignment="Center" />
                            <TextBlock x:Name="_sidetoneLbl"
                                       Text="50 %"
                                       Classes="mono"
                                       VerticalAlignment="Center" MinWidth="36" />
                        </StackPanel>
                        <TextBlock x:Name="_sidetoneStatus"
                                   Text=""
                                   FontSize="11"
                                   Foreground="#606070" />
                    </StackPanel>
                </Border>

                <!-- HID monitor -->
                <Border Padding="10,8">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="HID Monitor"
                                       Classes="header" />
                            <TextBlock x:Name="_rawBytesLbl"
                                       Text="Bytes: -- --"
                                       Classes="mono"
                                       Foreground="#606070"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <!-- Button dots added programmatically in code-behind -->
                        <WrapPanel x:Name="_buttonContainer" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
